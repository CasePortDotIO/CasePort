// Check if the hero background image is loaded
const heroImg = document.querySelector('section img[src*="hero-bg"]');
if (heroImg) {
  console.log('Hero image found:', {
    src: heroImg.src,
    complete: heroImg.complete,
    naturalWidth: heroImg.naturalWidth,
    naturalHeight: heroImg.naturalHeight,
    currentSrc: heroImg.currentSrc
  });
} else {
  console.log('Hero image NOT found in DOM');
}

// Check the section background
const section = document.querySelector('section');
if (section) {
  const styles = window.getComputedStyle(section);
  console.log('Section background:', styles.backgroundImage);
}

